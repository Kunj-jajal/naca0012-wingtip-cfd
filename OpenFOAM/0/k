FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      k;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -2 0 0 0 0];


internalField   uniform 0.00906153;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform 0.00906153;
    }

    outlet
    {
        type            inletOutlet;
        inletValue      uniform 0.00906153;
        value           uniform 0.00906153;
    }

    top
    {
        type            zeroGradient;
    }

    bottom
    {
        type            zeroGradient;
    }

    back
    {
        type            symmetryPlane;
    }

    front
    {
        type            zeroGradient;
    }

    wing
    {
        type            kqRWallFunction;
        value           uniform 0.00906153;
    }
}


