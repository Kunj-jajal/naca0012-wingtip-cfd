FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      epsilon;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -3 0 0 0 0];

internalField   uniform 0.000636751;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform 0.000636751;
    }

    outlet
    {
        type            inletOutlet;
        inletValue      uniform 0.000636751;
        value           uniform 0.000636751;
    }

    top
    {
        type            zeroGradient;
    }

    bottom
    {
        type            zeroGradient;
    }

    front
    {
        type            zeroGradient;
    }

    back
    {
        type            symmetryPlane;
    }

    wing
    {
        type            epsilonWallFunction;
        value           uniform 0.000636751;
    }
}


