FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 -1 0 0 0 0];

internalField   uniform (51.029 8.997 0);

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform (51.029 8.997 0);
    }

    outlet
    {
        type        inletOutlet;
		inletValue  uniform (51.029 8.997 0);
		value       uniform (51.029 8.997 0);
    }

    top
    {
        type            slip;
    }

    bottom
    {
        type            slip;
    }

    wing
    {
        type            noSlip;
    }

    front
    {
        type            slip;
    }
    
    back
    {
        type            symmetryPlane;
    }
}


