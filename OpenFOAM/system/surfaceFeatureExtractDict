FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      surfaceFeatureExtractDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

wing.stl
{
    // Extract sharp feature edges from the STL surface.
    // includedAngle: edges whose adjacent face normals differ by more than
    // (180 - includedAngle) degrees are extracted as features.
    // 150° catches the sharp LE/TE edges without over-extracting smooth surfaces.
    extractionMethod    extractFromSurface;

    extractFromSurfaceCoeffs
    {
        includedAngle   150;
    }

    // Write a .obj alongside the .eMesh for visual inspection in ParaView
    writeObj            yes;
}

