FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //


application     pimpleFoam;

startFrom       latestTime;        

startTime       0;

stopAt          endTime;

endTime         10;                 

deltaT          1e-3;               

writeControl    runTime;

writeInterval   0.01;                

purgeWrite      0;                  

writeFormat     binary;         
    
writePrecision  6;

writeCompression off;

timeFormat      general;

timePrecision   6;

adjustTimeStep  no;

maxCo           1;

maxDeltaT       1e-2;

functions
{

    QCriterion
    {
        type            Q;
        libs            (fieldFunctionObjects);
        
        writeControl    writeTime;
        log             on;
    }

    vorticity
    {
        type            vorticity;
        libs            (fieldFunctionObjects);
        writeControl    writeTime;
        writeFields     yes;
        log             on;
    }

    CpStatic
    {
        type            pressure;
        libs            (fieldFunctionObjects);

        mode            staticCoeff;

        p               p;
        U               U;
        
        rho             rhoInf;
        rhoInf          1.225;      

        pInf            0.0;        
        UInf            (51.816 0 0);    

        result          CpStatic;   
        writeControl    writeTime;
        log             off;
    }

    CpTotal
    {
        type            pressure;
        libs            (fieldFunctionObjects);

        mode            totalCoeff;

        p               p;
        U               U;
        
        rho             rhoInf;
        rhoInf          1.225;      

        pInf            0.0;        
        UInf            (51.816 0 0);

        result          CpTotal;
        writeControl    writeTime;
        log             off;
    }

    // ── Probe / sample locations ──────────────────────────────────────────
    // sampleDict-based probes will be added here once the pre-processed
    // experimental probe locations are confirmed.  Placeholder:
