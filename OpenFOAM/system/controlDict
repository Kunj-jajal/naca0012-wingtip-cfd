FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     pimpleFoam;

startFrom       latestTime;

startTime       0;

stopAt          endTime;

endTime         4000;

deltaT          0.0001;

writeControl    timeStep;

writeInterval   20;

purgeWrite      0;

writeFormat     binary;

writePrecision  6;

writeCompression off;

timeFormat      general;

timePrecision   6;

runTimeModifiable true;

adjustTimeStep  no;

maxCo           0.3;

logFile			log;

functions
{
	vorticity1
	{
		// Mandatory entries (unmodifiable)
		type        vorticity;
		libs        (fieldFunctionObjects);

		// Optional (inherited) entries
		field           <inpField>;
		result          <fieldResult>;
		region          region0;
		enabled         true;
		log             true;
		timeStart       0;
		timeEnd         4000;
		executeControl  timeStep;
		executeInterval 5;
		writeControl    timeStep;
		writeInterval   2;
	}
}
