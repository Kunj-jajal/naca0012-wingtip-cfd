FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      snappyHexMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

castellatedMesh true;
snap            true;
addLayers       true;


// Geometry
geometry
{
    wing.stl
    {
        type triSurfaceMesh;
        name wing;
    }

    refinementBox
    {
        type box;

        // MODIFY THESE TO FIT YOUR AIRFOIL
        min (-1.0 -0.5 -0.5);
        max ( 2.0  0.5  0.5);
    }
}


// Castellated mesh controls
castellatedMeshControls
{
    maxLocalCells       100000;
    maxGlobalCells      5000000;

    minRefinementCells  0;
    maxLoadUnbalance    0.10;

    nCellsBetweenLevels 3;


    features
    (
        {
            file "wing.eMesh";
            level 6;
        }
    );


    refinementSurfaces
    {
        wing
        {
            level (5 6);

            patchInfo
            {
                type wall;
            }
        }
    }


    resolveFeatureAngle 30;


    refinementRegions
    {
        refinementBox
        {
            mode inside;
            levels ((1E15 3));
        }
    }


    locationInMesh (1 0 0);


    allowFreeStandingZoneFaces true;
}


// Snap controls
snapControls
{
    nSmoothPatch 5;

    tolerance 2.0;

    nSolveIter 30;

    nRelaxIter 8;

    nFeatureSnapIter 15;

    implicitFeatureSnap false;

    explicitFeatureSnap true;

    multiRegionFeatureSnap false;
}


// Layer controls
addLayersControls
{
    relativeSizes false;


    layers
    {
        wing
        {
            nSurfaceLayers 15;
        }
    }


    expansionRatio 1.20;


    // y+ ≈ 1 estimate
    firstLayerThickness 7.6e-6;


    // total prism-layer thickness
    finalLayerThickness 5.0e-3;

    minThickness 1.0e-6;


    nGrow 0;


    featureAngle 60;

    slipFeatureAngle 30;

    nRelaxIter 5;

    nSmoothSurfaceNormals 3;

    nSmoothNormals 5;

    nSmoothThickness 10;

    maxFaceThicknessRatio 0.5;

    maxThicknessToMedialRatio 0.3;

    minMedialAxisAngle 90;

    nBufferCellsNoExtrude 0;

    nLayerIter 50;
}


// Mesh quality
meshQualityControls
{
    #include "meshQualityDict"

    nSmoothScale 4;
    errorReduction 0.75;
}


// Output
writeFlags
(
    scalarLevels
    layerSets
    layerFields
);


mergeTolerance 1e-6;
// ************************************************************************* //
