FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      snappyHexMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
// NOTE: All coordinates are in INCHES to match wing.stl and blockMesh domain.
//       Domain: 240 x 32 x 48 inches. Chord c = 48 inches.
//       y+ = 1 target → firstLayerThickness = 3.0e-4 inches (= 7.6e-6 m)

castellatedMesh true;
snap            true;
addLayers       true;

// ─────────────────────────────────────────────────────────────
// Geometry
// ─────────────────────────────────────────────────────────────
geometry
{
    wing.stl
    {
        type triSurfaceMesh;
        name wing;
    }

    // Wake + near-wing refinement box (inches).
    // Adjust min/max once you confirm STL origin placement.
    refinementBox
    {
        type box;
        min (-0.6096  -0.254 -0.0254);   // 0.5c upstream, 0.5c below, just inside root
        max ( 2.4384   0.254  1.27   );   // 2c downstream, 0.5c above, past tip (48 in span)
    }
}

// ─────────────────────────────────────────────────────────────
// Castellated mesh controls
// ─────────────────────────────────────────────────────────────
castellatedMeshControls
{
    maxLocalCells       100000;
    maxGlobalCells      5000000;    // Increase to 20-50M when you refine blockMesh
    minRefinementCells  0;
    maxLoadUnbalance    0.10;
    nCellsBetweenLevels 3;

    // wing.eMesh is generated by surfaceFeatureExtract
    features
    (
        {
            file    "wing.eMesh";
            level   6;
        }
    );

    refinementSurfaces
    {
        wing
        {
            level (5 6);
            patchInfo
            {
                type wall;
            }
        }
    }

    resolveFeatureAngle 30;

    refinementRegions
    {
        refinementBox
        {
            mode    inside;
            levels  ((1E15 3));
        }
    }

    // Seed point: clearly inside the domain, outside the wing.
    // Placed ~1 chord upstream of LE at mid-height.
    // *** VERIFY this point is not inside wing.stl ***
    locationInMesh (-1.2192 0.127 0.254);

    allowFreeStandingZoneFaces true;
}

// ─────────────────────────────────────────────────────────────
// Snap controls
// ─────────────────────────────────────────────────────────────
snapControls
{
    nSmoothPatch            5;
    tolerance               2.0;
    nSolveIter              30;
    nRelaxIter              8;
    nFeatureSnapIter        15;
    implicitFeatureSnap     false;
    explicitFeatureSnap     true;   // requires wing.eMesh from surfaceFeatureExtract
    multiRegionFeatureSnap  false;
}

// ─────────────────────────────────────────────────────────────
// Layer controls
// ─────────────────────────────────────────────────────────────
addLayersControls
{
    relativeSizes   false;          // absolute thickness values

    layers
    {
        wing
        {
            nSurfaceLayers 15;
        }
    }

    expansionRatio          1.20;

    // y+ ≈ 1 → first cell height = 7.6e-6 m
    // Do NOT also specify finalLayerThickness — over-constrains the solver.
    firstLayerThickness     7.6e-6;

    minThickness            2.54e-7; // keep > firstLayerThickness/10

    nGrow                   0;
    featureAngle            60;
    slipFeatureAngle        30;
    nRelaxIter              5;
    nSmoothSurfaceNormals   3;
    nSmoothNormals          5;
    nSmoothThickness        10;
    maxFaceThicknessRatio   0.5;
    maxThicknessToMedialRatio 0.5;  // raised from 0.3; 0.3 is too tight for a wingtip
    minMedialAxisAngle      90;
    nBufferCellsNoExtrude   0;
    nLayerIter              50;
}

// ─────────────────────────────────────────────────────────────
// Mesh quality
// ─────────────────────────────────────────────────────────────
meshQualityControls
{
    #include "meshQualityDict"
    nSmoothScale    4;
    errorReduction  0.75;
}

writeFlags
(
    scalarLevels
    layerSets
    layerFields
);

mergeTolerance 1e-6;

// ************************************************************************* //
