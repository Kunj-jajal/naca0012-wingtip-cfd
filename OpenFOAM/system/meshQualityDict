FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      meshQualityDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
// These are the DEFAULT OpenFOAM quality thresholds.
// snappyHexMesh will relax these automatically during layer addition
// via the nSmoothScale / errorReduction entries in snappyHexMeshDict.

// ── Cell shape ──────────────────────────────────────────────────────────────

// Maximum non-orthogonality angle (degrees).
// 70–75 is acceptable for a first run; tighten to 65 once mesh is stable.
maxNonOrtho         70;

// Maximum skewness. 4 is the default; lower = better quality.
maxBoundarySkewness 20;
maxInternalSkewness 4;

// Max concavity of a cell (degrees). 80 is default.
maxConcave          80;

// Minimum cell pyramid volume as fraction of the largest pyramid.
// Negative values allow a small number of zero/negative pyramids during snapping.
minVol              1e-13;

// Minimum quality of the tet decomposition used for cell-centre location.
// -1e30 effectively disables this check on early passes.
minTetQuality       1e-30;

// Minimum face area.
minArea             -1;

// ── Face shape ──────────────────────────────────────────────────────────────

// Minimum face twist (dot product of face normal and face-centre-to-cell-centre
// vector). -1 disables.
minTwist            0.02;

// Minimum normalised cell determinant (1 = hex, 0 = degenerate).
minDeterminant      0.001;

// Minimum face interpolation weight (0.5 = perfectly centred).
minFaceWeight       0.02;

// Minimum face volume ratio between owner and neighbour cells.
minVolRatio         0.01;

// Minimum angle between face normal and cell-to-cell vector.
minTriangleTwist    -1;

// ── Topology ────────────────────────────────────────────────────────────────

// Number of error distribution smoothing iterations.
nSmoothScale        4;

// Amount by which to scale back the error on each iteration (0–1).
errorReduction      0.75;

// ************************************************************************* //
